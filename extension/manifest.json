{
  "manifest_version": 3,
  "name": "NL2Cal",
  "version": "1.0.0",
  "description": "Natural language to Google Calendar — create, delete, and RSVP to events by typing naturally.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NL2Cal"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
